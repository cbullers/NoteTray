<Window x:Class="NoteTray.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteTray"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource PanelBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20">
        <StackPanel MinWidth="250">
            <TextBlock x:Name="PromptText"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="14"
                       Margin="0,0,0,10"/>

            <TextBox x:Name="InputTextBox"
                     Background="{StaticResource PanelSurface}"
                     Foreground="{StaticResource TextPrimary}"
                     CaretBrush="{StaticResource TextPrimary}"
                     BorderBrush="{StaticResource PanelBorder}"
                     FontSize="14"
                     Padding="8,6"
                     Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource PanelButton}"
                        Click="Cancel_Click"
                        Margin="0,0,8,0"/>
                <Button Content="OK"
                        Style="{StaticResource PanelButton}"
                        Click="OK_Click"
                        IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
